<body>
    
    <Nav />


    <section class="hero" id="home">
        <div class="hero-bg"></div>
        <div class="hero-container">
            <div class="hero-left">
                <h1 class="hero-title">
                    <span class="line"><span>Custom</span></span>
                    <span class="line"><span class="accent">3D Design</span></span>
                    <span class="line"><span>Solutions</span></span>
                </h1>
                <p class="hero-description">
                    Discover our 3D printing and scanning services, where innovation meets precision. We bring your ideas to life with cutting-edge technology and expert craftsmanship, delivering custom solutions that exceed expectations.
                </p>
                <div class="hero-stats">
                    <div class="stat">
                        <span class="stat-number">3D Printing</span>
                        <span class="stat-label">Custom Prints</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">3D Scanning</span>
                        <span class="stat-label">Reverse CAD Engineering</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">NZ Owned</span>
                        <span class="stat-label">Local Innovation</span>
                    </div>
                </div>
                <div class="cta-group">
                    <a href="/tools" class="cta-button primary">Explore Our Tools</a>
                    <a href="/about" class="cta-button outline">About Us</a>
                </div>
            </div>
            
            <div class="hero-right">
                <div class="hero-image-wrapper">
                    <div class="hero-carousel">
                        <div class="carousel-slide active">
                            <img src="images/3dprint4.avif">
                        </div>
                        <div class="carousel-slide">
                            <img src="images/3dprint5.avif">
                        </div>
                        <div class="carousel-slide">
                            <img src="images/3dprint6.avif">
                        </div>
                        <div class="carousel-overlay"></div>
                        <div class="carousel-indicators">
                            <span class="indicator active" data-slide="0"></span>
                            <span class="indicator" data-slide="1"></span>
                            <span class="indicator" data-slide="2"></span>
                        </div>
                    </div>
                    <div class="floating-tags">
                        <div class="tag">Custom CAD</div>
                        <div class="tag">Product Design</div>
                        <div class="tag">3D Scanning</div>
                    </div>
                </div>
            </div>
        </div>
