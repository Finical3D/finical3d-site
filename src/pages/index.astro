---
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import FeaturedImage from '../components/FeaturedImage.astro';
import Contactform from '../components/Contact-form.astro';

---

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Finical 3D - 3D Innovation</title>
    <link rel="stylesheet" href="/finical3d-main.css">

</head>
<body>
    
    <Nav />


    <section class="hero" id="home">
        <div class="hero-bg"></div>
        <div class="hero-container">
            <div class="hero-left">
                <h1 class="hero-title">
                    <span class="line"><span>Custom</span></span>
                    <span class="line"><span class="accent">3D Design</span></span>
                    <span class="line"><span>Solutions</span></span>
                </h1>
                <p class="hero-description">
                    Discover our 3D printing and scanning services, where innovation meets precision. We bring your ideas to life with cutting-edge technology and expert craftsmanship, delivering custom solutions that exceed expectations.
                </p>
                <div class="hero-stats">
                    <div class="stat">
                        <span class="stat-number">3D Printing</span>
                        <span class="stat-label">Custom Prints/<br>Print Services</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">3D Scanning</span>
                        <span class="stat-label">Reverse CAD Engineering</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">NZ Owned</span>
                        <span class="stat-label">Local Innovation/<br>Manufacturing</span>
                    </div>
                </div>
                <div class="cta-group">
                    <a href="/tools" class="cta-button primary">Explore Our Tools</a>
                    <a href="/about" class="cta-button outline">About Us</a>
                </div>
            </div>
            
            <div class="hero-right">
                <div class="hero-image-wrapper">
                    <div class="hero-carousel">
                        <div class="carousel-slide active">
                            <img src="images/3dprint2.png">
                        </div>
                        <div class="carousel-slide">
                            <img src="images/3dprint1.png">
                        </div>
                        <div class="carousel-slide">
                            <img src="images/3dprint3.png">
                        </div>
                        <div class="carousel-overlay"></div>
                        <div class="carousel-indicators">
                            <span class="indicator active" data-slide="0"></span>
                            <span class="indicator" data-slide="1"></span>
                            <span class="indicator" data-slide="2"></span>
                        </div>
                    </div>
                    <div class="floating-tags">
                        <div class="tag">Custom CAD</div>
                        <div class="tag">Product Design</div>
                        <div class="tag">3D Scanning</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="featured" id="featured">
        <div class="featured-container">
            <div class="featured-hero">
                <div class="featured-content">
                    <span class="label">Crafted with Passion</span>
                    <h2>The Art of 3D Printing</h2>
                    <p>Discover the fusion of technology and creativity in our 3D printed collections. Each item is a testament to the endless possibilities of modern manufacturing.</p>
                    
                    <div class="feature-highlights">
                        <div class="highlight-item">
                            <div class="highlight-icon"><svg xmlns="http://www.w3.org/2000/svg" height="35px" viewBox="0 -960 960 960" width="35px" fill="#000000"><path d="m387-412 35-114-92-74h114l36-112 36 112h114l-93 74 35 114-92-71-93 71ZM240-40v-309q-38-42-59-96t-21-115q0-134 93-227t227-93q134 0 227 93t93 227q0 61-21 115t-59 96v309l-240-80-240 80Zm410-350q70-70 70-170t-70-170q-70-70-170-70t-170 70q-70 70-70 170t70 170q70 70 170 70t170-70ZM320-159l160-41 160 41v-124q-35 20-75.5 31.5T480-240q-44 0-84.5-11.5T320-283v124Zm160-62Z"/></svg></div>
                            <div class="highlight-title">Premium Quality</div>
                            <div class="highlight-desc">Only the finest quality filaments and resins used</div>
                        </div>
							<div class="highlight-item">
                            <div class="highlight-icon"><svg xmlns="http://www.w3.org/2000/svg" height="35px" viewBox="0 -960 960 960" width="35px" fill="#000000"><path d="m352-522 86-87-56-57-44 44-56-56 43-44-45-45-87 87 159 158Zm328 329 87-87-45-45-44 43-56-56 43-44-57-56-86 86 158 159Zm24-567 57 57-57-57ZM290-120H120v-170l175-175L80-680l200-200 216 216 151-152q12-12 27-18t31-6q16 0 31 6t27 18l53 54q12 12 18 27t6 31q0 16-6 30.5T816-647L665-495l215 215L680-80 465-295 290-120Zm-90-80h56l392-391-57-57-391 392v56Zm420-419-29-29 57 57-28-28Z"/></svg></div>
                            <div class="highlight-title">Careful Design</div>
                            <div class="highlight-desc">Each piece is designed for both form and function</div>
                        </div>
                        <div class="highlight-item">
                            <div class="highlight-icon"><svg xmlns="http://www.w3.org/2000/svg" height="40px" viewBox="0 -960 960 960" width="40px" fill="#000000"><path d="M214-175.33q-44.06-45-69.03-104T120-400.67q0-69.66 25-130.5Q170-592 222-644q35-35 86.83-59.33 51.84-24.34 122.34-38.17 70.5-13.83 160-17.17 89.5-3.33 199.5 4.67 8 107.33 5.33 196.67-2.67 89.33-16.17 160.66-13.5 71.34-38 124.71-24.5 53.38-60.5 89.29Q629.67-131 570.5-105.5T446-80q-67.67 0-126.67-24.17-59-24.16-105.33-71.16Zm106-5.34q26.33 17 58.5 25.5t67.45 8.5q50.72 0 99.05-20.83t89.33-62.5q24-24 42.84-63.83 18.83-39.84 31.33-97Q721-448 726-522.83q5-74.84.67-169.17-79-2-149.17 1.17-70.17 3.16-128.5 14.16t-104 30q-45.67 19-74.67 48.67-43 43.67-63.33 90.33Q186.67-461 186.67-414q0 51.67 21.16 101.5 21.17 49.83 46.84 77.17 49.33-92 121.66-168.5 72.34-76.5 158.34-122.17-82 71-135.84 155.83Q345-285.33 320-180.67Zm0 0Zm0 0Z"/></svg></div>
                            <div class="highlight-title">Sustainable</div>
                            <div class="highlight-desc">Eco-Friendly recycling and re-use of filament</div>
                        </div>
                    </div>
                    
                    <div class="feature-cta-wrapper">
                    <a href="#collections" class="feature-cta">Discover Our Craft</a>
                    </div>
                </div>
                
<FeaturedImage />
            </div>
        </div>
    </section>

    <div class="contact-compact">
        <Contactform />
    </div>
  
    <Footer />

    <script is:inline src="/finical3d-scripts.js"></script>
</body>
</html>