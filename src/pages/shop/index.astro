---
import Layout from '../../layouts/Layout.astro';
import { products, collections } from '../../data/products.js';
---

<Layout title="Shop - Finical 3D" noindex={true}>

    <section class="shop-hero">
        <div class="about-hero-content">
            <h1 class="hero-title">
                <span class="line"><span class="accent">Finical</span><span class="logo-colors">Shop</span></span>
            </h1>
            <p class="hero-description">
                Professionally printed miniatures and models, ready to ship.
            </p>
        </div>
    </section>

    <section class="featured">
        <div class="featured-container">

            <div class="collections-grid">
                {collections.map(collection => (
                    <a href={`/shop/collections/${collection.slug}`} class="collection-card">
                        <h3>{collection.name}</h3>
                        <p>{collection.description}</p>
                        <span class="collection-count">
                            {products.filter(p => p.collections?.includes(collection.slug)).length} products
                        </span>
                    </a>
                ))}
            </div>

            <h2 class="shop-all-title">All Products</h2>
            <div class="shop-grid">
                {products.map(product => (
                    <a href={`/shop/${product.slug}`} class="shop-card">
                        <div class="shop-card-image">
                            <img src={product.image} alt={product.name}>
                        </div>
                        <div class="shop-card-content">
                            <h3>{product.name}</h3>
                            <p class="shop-card-material">{product.materials?.join(' / ')} · {product.scale}</p>
                            <p class="shop-card-price">${product.price.toFixed(2)} NZD</p>
                        </div>
                    </a>
                ))}
            </div>

        </div>
    </section>

</Layout>

<style>
    .shop-hero {
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 70px 50px 0;
        width: 100%;
    }

    .shop-hero .about-hero-content {
        text-align: center;
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
    }

    .shop-hero .hero-title {
        text-align: center;
        width: 100%;
    }

    .shop-hero .hero-description {
        text-align: center;
    }

    @media (max-width: 768px) {
        .shop-hero {
            padding: 10px 20px 0;
            text-align: center;
        }

        .collection-card h3 {
            text-align: center;
            margin-bottom: 0px;
        }
        
        .collection-card{
            text-align: center;
        }

        .collection-card p {
        display: none;
    }
    }
</style>