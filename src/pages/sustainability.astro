                </div>
            </div>

        </div>
    </section>

    <Footer />

    <script is:inline src="/finical3d-scripts.js"></script>
</body>
</html>

<style>
    .about-hero {
        min-height: 50vh;
        position: relative;
        overflow: hidden;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .about-hero-content {
        position: relative;
        z-index: 2;
        padding: 140px 50px 80px;
        max-width: 900px;
        width: 100%;
        margin: 0 auto;
        text-align: center;
        overflow: visible;
    }

    /* Use :global to escape Astro scoping and override the global CSS */
    :global(.about-hero .hero-title) {
        font-size: clamp(28px, 6vw, 90px);
        text-align: center;
        width: 100%;
        overflow: visible;
        white-space: normal;
        word-break: normal;
    }

    :global(.about-hero .hero-title .line) {
        overflow: visible !important;
        display: block !important;
        text-align: center;
    }

    :global(.about-hero .hero-title .line span) {
        display: block !important;
        text-align: center;
    }

    .feature-highlights {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        margin-bottom: 40px;
    }

    @media (max-width: 768px) {
        :global(.about-hero .hero-title) {
            font-size: clamp(26px, 8vw, 60px);
        }

        .feature-highlights {
            grid-template-columns: 1fr;
        }

        .about-hero-content {
            padding: 120px 20px 60px;
        }
    }

    @media (max-width: 390px) {
        :global(.about-hero .hero-title) {
            font-size: clamp(22px, 7.5vw, 40px);
        }
    }
</style>