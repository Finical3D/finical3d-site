---
import Layout from '../layouts/Layout.astro';
import FeaturedImage from '../components/FeaturedImage.astro';
---

<Layout title="About Finical 3D">

    <section class="about-hero">
        <div class="hero-bg"></div>
        <div class="about-hero-content">
            <h1 class="hero-title">
                <span class="line"><span>About</span></span>
                <span class="line"><span class="accent">Finical 3D</span></span>
            </h1>
            <p class="hero-description">
                A New Zealand owned studio pushing the boundaries of 3D printing, scanning, and CAD design.
            </p>
        </div>
    </section>

    <section class="featured">
        <div class="featured-container">
            <div class="featured-hero">
                <div class="featured-content">
                    <span class="label">Who We Are</span>
                    <h2>Our Mission</h2>
                    <p>We are dedicated to pushing the boundaries of 3D printing and CAD design, creating solutions that inspire and empower our clients. Based in Christchurch, we bring precision and creativity to every project.</p>
                    <h2>Members</h2>
                    <img src="/images/matty.png" alt="Matty" style="width: 150px; border-radius: 50%; margin: 20px 0; padding-bottom:20px;">
                    <p>Matty - Founder & Lead Designer</p>
                    <p>Proven 3D skills and experience in the automotive industry. Specializing in 3D scanning and reverse engineering alongside 3D printing prototypes and products for manufacture.</p>
                    <a href="/#contact" class="feature-cta">Get In Touch</a>
                </div>
                <FeaturedImage />
            </div>

            <div class="feature-highlights" style="margin-top: 60px;">
                <!-- your highlight items unchanged -->
            </div>
        </div>
    </section>

</Layout>

<style>
    .about-hero {
        min-height: 50vh;
        position: relative;
        overflow: hidden;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .about-hero-content {
        position: relative;
        z-index: 2;
        padding: 140px 50px 0px;
        max-width: 800px;
    }

    .feature-highlights {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        margin-bottom: 40px;
    }

    @media (max-width: 768px) {
        .feature-highlights {
            grid-template-columns: 1fr;
        }

        .about-hero-content {
            padding: 120px 20px 60px;
        }
    }
</style>