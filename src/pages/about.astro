---
const title = "About Finical 3D";
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="stylesheet" href="/finical3d-main.css">
</head>
<body>
    <Nav />

    <section class="about-hero">
        <div class="hero-bg"></div>
        <div class="about-hero-content">
            <h1 class="hero-title">
                <span class="line"><span>About</span></span>
                <span class="line"><span class="accent">Finical 3D</span></span>
            </h1>
            <p class="hero-description">
                A New Zealand owned studio pushing the boundaries of 3D printing, scanning, and CAD design.
            </p>
        </div>
    </section>

    <section class="featured">
        <div class="featured-container">

            <div class="featured-hero">
                <div class="featured-content">
                    <span class="label">Who We Are</span>
                    <h2>Our Mission</h2>
                    <p>We are dedicated to pushing the boundaries of 3D printing and CAD design, creating solutions that inspire and empower our clients. Based in Christchurch, we bring precision and creativity to every project.</p>
                    <h2>Members</h2>
                    <p>Matty - Founder & Lead Designer</p>
                    <img src="/images/matty.avif" alt="Matty" style="width: 150px; border-radius: 50%; margin: 20px 0;">
                    <p>Proven 3D skills and experience in the automotive industry. Specializing in 3D scanning and reverse engineering alongside 3D printing prototypes and products for manufacture.</p>
                    <a href="/#contact" class="feature-cta">Get In Touch</a>
                </div>
                <div class="featured-image-section">
                    <div class="featured-image-grid">
                        <div class="featured-img">
                            <img src="/images/3dprint1.avif">
                        </div>
                        <div class="featured-img">
                            <img src="/images/3dprint2.avif">
                        </div>
                        <div class="featured-img">
                            <img src="/images/3dprint3.avif">
                        </div>
                    </div>
                </div>
            </div>

            <div class="feature-highlights" style="margin-top: 60px;">
                <div class="highlight-item">
                    <div class="highlight-icon"><svg xmlns="http://www.w3.org/2000/svg" height="40px" viewBox="0 -960 960 960" width="40px" fill="#000000"><path d="M652-645.33v-128H308v128h-66.67V-840h477.34v194.67H652Zm-505.33 66.66h666.66-666.66Zm586 96.67q13.66 0 23.5-9.83 9.83-9.84 9.83-23.5 0-13.67-9.83-23.5-9.84-9.84-23.5-9.84-13.67 0-23.5 9.84-9.84 9.83-9.84 23.5 0 13.66 9.84 23.5Q719-482 732.67-482ZM652-186.67V-368H308v181.33h344ZM718.67-120H241.33v-170.67H80v-244q0-47.03 32-78.85 32-31.81 78.67-31.81h578.66q47.04 0 78.85 31.81Q880-581.7 880-534.67v244H718.67V-120Zm94.66-237.33v-177.48q0-18.86-12.65-31.36t-31.35-12.5H190.67q-18.7 0-31.35 12.65-12.65 12.65-12.65 31.35v177.34h94.66v-77.34h477.34v77.34h94.66Z"/></svg></div>
                    <div class="highlight-title">3D Printing</div>
                    <div class="highlight-desc">Custom FDM and resin printing services for prototypes and end-use parts</div>
                </div>
                <div class="highlight-item">
                    <div class="highlight-icon"><svg xmlns="http://www.w3.org/2000/svg" height="40px" viewBox="0 -960 960 960" width="40px" fill="#000000"><path d="M202.67-120q-34.34 0-58.5-24.17Q120-168.33 120-202.67v-542q0-34.33 32-47.5 32-13.16 56.67 11.5l60 60-46 46L250-647.33l46-46 112.67 112.66-46 46L390-507.33l46-46L549.33-440l-46 46 27.34 27.33 46-46L689.33-300l-46 46 27.34 27.33 46-46L773.33-216q26.67 26.67 12.84 61.33Q772.33-120 736-120H202.67Zm10.66-93.33h419.34L213.33-632.67v419.34Z"/></svg></div>
                    <div class="highlight-title">CAD Design</div>
                    <div class="highlight-desc">Reverse engineering and original CAD modelling for any application</div>
                </div>
                <div class="highlight-item">
                    <div class="highlight-icon"><svg xmlns="http://www.w3.org/2000/svg" height="40px" viewBox="0 -960 960 960" width="40px" fill="#000000"><path d="M792-120.67 532.67-380q-30 25.33-69.67 39.67Q423.33-326 378.67-326q-108.34 0-183.5-75.17Q120-476.33 120-583.33t75.17-182.17q75.16-75.17 182.83-75.17 107 0 181.83 75.17 74.84 75.17 74.84 182.17 0 43.33-14 83-14 39.66-40.67 73l260 258.66-48 48Zm-414-272q79 0 134.5-55.83T568-583.33q0-79-55.5-134.84Q457-774 378-774q-79.67 0-135.5 55.83-55.83 55.84-55.83 134.84T242.5-448.5q55.83 55.83 135.5 55.83Z"/></svg></div>
                    <div class="highlight-title">3D Scanning</div>
                    <div class="highlight-desc">High-accuracy scanning to capture real-world objects as digital models</div>
                </div>
                <div class="highlight-item">
                    <div class="highlight-icon"><svg xmlns="http://www.w3.org/2000/svg" height="40px" viewBox="0 -960 960 960" width="40px" fill="#000000"><path d="M214-175.33q-44.06-45-69.03-104T120-400.67q0-69.66 25-130.5Q170-592 222-644q35-35 86.83-59.33 51.84-24.34 122.34-38.17 70.5-13.83 160-17.17 89.5-3.33 199.5 4.67 8 107.33 5.33 196.67-2.67 89.33-16.17 160.66-13.5 71.34-38 124.71-24.5 53.38-60.5 89.29Q629.67-131 570.5-105.5T446-80q-67.67 0-126.67-24.17-59-24.16-105.33-71.16Zm106-5.34q26.33 17 58.5 25.5t67.45 8.5q50.72 0 99.05-20.83t89.33-62.5q24-24 42.84-63.83 18.83-39.84 31.33-97Q721-448 726-522.83q5-74.84.67-169.17-79-2-149.17 1.17-70.17 3.16-128.5 14.16t-104 30q-45.67 19-74.67 48.67-43 43.67-63.33 90.33Q186.67-461 186.67-414q0 51.67 21.16 101.5 21.17 49.83 46.84 77.17 49.33-92 121.66-168.5 72.34-76.5 158.34-122.17-82 71-135.84 155.83Q345-285.33 320-180.67Zm0 0Zm0 0Z"/></svg></div>
                    <div class="highlight-title">Sustainable</div>
                    <div class="highlight-desc">Closed-loop filament recycling and eco-conscious manufacturing</div>
                </div>
                <div class="highlight-item">
                    <div class="highlight-icon"><svg xmlns="http://www.w3.org/2000/svg" height="40px" viewBox="0 -960 960 960" width="40px" fill="#000000"><path d="M480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q78 0 147.67 28.17 69.66 28.16 123.33 77.16t87.33 116q33.67 67 40 144.67-16.66-9.67-34.33-16.33-17.67-6.67-36.67-11-15.66-85-69.16-151t-133.5-99V-774q0 34.33-23.84 59.5-23.83 25.17-58.16 25.17H438v84.66q0 17-12.83 28.17-12.84 11.17-29.84 11.17h-82V-480H598q-31 31.33-47.83 71.33-16.84 40-16.84 84.67 0 76 31.34 117.33 31.33 41.34 79 91.67Q605-97.67 564-88.83 523-80 480-80Zm-42-68v-80.67q-34.33 0-58.17-25.16Q356-279 356-313.33V-356L155.33-556.67q-4.33 19.34-6.5 38.34-2.16 19-2.16 38.33 0 127 82.83 222T438-148Zm364.5-129.5Q820-295 820-320t-17-42.5Q786-380 761-380q-26 0-43.5 17.5T700-320q0 25 17.5 42.5T760-260q25 0 42.5-17.5ZM760-80q-3 0-16-11l-4-7q-22-38-55.5-67.5T627-232q-14-20-20.5-43.5T600-324q0-66 47-111t113-45q66 0 113 45t47 111q0 25-6.5 48.5T893-232q-24 37-57.5 66.5T780-98l-4 7q-2 5-6.5 8t-9.5 3Z"/></svg></div>
                    <div class="highlight-title">NZ Owned</div>
                    <div class="highlight-desc">Proudly local, serving clients across New Zealand</div>
                </div>
                <div class="highlight-item">
                    <div class="highlight-icon"><svg xmlns="http://www.w3.org/2000/svg" height="40px" viewBox="0 -960 960 960" width="40px" fill="#000000"><path d="m385.67-412 35.66-114.67-94-74h115.34L480-717.33l36.67 116.66h116l-94.34 74 35 114.67L480-483l-94.33 71Zm-143 372v-305.67Q200-391 180-446.33 160-501.67 160-560q0-135.33 92.33-227.67Q344.67-880 480-880q135.33 0 227.67 92.33Q800-695.33 800-560q0 58.33-20 113.67-20 55.33-62.67 100.66V-40L480-119.33 242.67-40Zm417-340.33Q733.33-454 733.33-560q0-106-73.66-179.67Q586-813.33 480-813.33q-106 0-179.67 73.66Q226.67-666 226.67-560q0 106 73.66 179.67Q374-306.67 480-306.67q106 0 179.67-73.66ZM309.33-135.67 480-186l170.67 50.33V-291q-38.34 26-82.5 38.5Q524-240 480-240t-88.17-12.5q-44.16-12.5-82.5-38.5v155.33Zm170.67-78Z"/></svg></div>
                    <div class="highlight-title">Premium Quality</div>
                    <div class="highlight-desc">Only the finest filaments and resins used in every print</div>
                </div>
            </div>

        </div>
    </section>

    <Footer />

    <script is:inline src="/finical3d-scripts.js"></script>
</body>
</html>

<style>
    .about-hero {
        min-height: 50vh;
        position: relative;
        overflow: hidden;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .about-hero-content {
        position: relative;
        z-index: 2;
        padding: 140px 50px 80px;
        max-width: 800px;
    }

    .feature-highlights {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        margin-bottom: 40px;
    }

    @media (max-width: 768px) {
        .feature-highlights {
            grid-template-columns: 1fr;
        }

        .about-hero-content {
            padding: 120px 20px 60px;
        }
    }
</style>