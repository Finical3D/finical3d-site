<section class="contact" id="contact">
    <div class="contact-container">
        <div class="contact-header" style="padding-top: 60px;">
            <h2 class="section-title">Requests and Queries</h2>
            <p class="section-subtitle">Let us know how we can assist you</p>
        </div>
        
        <div class="contact-content">
            <div class="contact-form-wrapper">
                <form id="contactForm" action="https://api.web3forms.com/submit" method="POST">
                    
                    <input type="hidden" name="access_key" value="eb2ee476-8879-4dbc-944a-8d786fb4a84f">
                    <input type="hidden" name="subject" value="New Finical 3D Enquiry">
                    <input type="hidden" name="from_name" value="Finical 3D Website">

                    <div class="form-row">
                        <div class="form-group">
                            <label for="firstName">First Name</label>
                            <input type="text" id="firstName" name="firstName" placeholder="John" required>
                        </div>
                        <div class="form-group">
                            <label for="lastName">Last Name</label>
                            <input type="text" id="lastName" name="lastName" placeholder="Doe" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" placeholder="john@example.com" required>
                    </div>

                    <div class="form-group">
                        <label for="subject">Subject</label>
                        <input type="text" id="subject" name="subject" placeholder="What are we making?" required>
                    </div>

                    <div class="form-group">
                        <label>Service Type</label>
                        <div class="service-buttons">
                            <button type="button" class="service-btn" data-value="3D Printing">3D Printing</button>
                            <button type="button" class="service-btn" data-value="3D Scanning">3D Scanning</button>
                            <button type="button" class="service-btn" data-value="CAD Design">CAD Design</button>
                            <button type="button" class="service-btn" data-value="Other">Other</button>
                        </div>
                        <input type="hidden" id="serviceType" name="serviceType">
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="material">Material / Finish</label>
                            <input type="text" id="material" name="material" placeholder="e.g. PLA, Resin, PETG">
                        </div>
                        <div class="form-group">
                            <label for="quantity">Quantity</label>
                            <div class="quantity-wrapper">
                                <button type="button" class="qty-btn" id="qtyDown">−</button>
                                <input type="number" id="quantity" name="quantity" value="1" min="1">
                                <button type="button" class="qty-btn" id="qtyUp">+</button>
                            </div>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="deadline">Deadline</label>
                            <input type="date" id="deadline" name="deadline">
                        </div>
                        <div class="form-group">
                            <label for="budget">Budget (NZD)</label>
                            <input type="text" id="budget" name="budget" placeholder="e.g. $50–$200">
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="message">Message</label>
                        <textarea id="message" name="message" placeholder="Tell us more about your project — dimensions, purpose, references..." required></textarea>
                    </div>

                    <button type="submit" class="form-submit">Send Message</button>
                </form>
            </div>
            
            <div class="contact-info">
                <div class="info-item">
                    <div class="info-icon"><svg xmlns="http://www.w3.org/2000/svg" height="35px" viewBox="0 -960 960 960" width="35px" fill="#000000"><path d="M536.5-503.5Q560-527 560-560t-23.5-56.5Q513-640 480-640t-56.5 23.5Q400-593 400-560t23.5 56.5Q447-480 480-480t56.5-23.5ZM480-186q122-112 181-203.5T720-552q0-109-69.5-178.5T480-800q-101 0-170.5 69.5T240-552q0 71 59 162.5T480-186Zm0 106Q319-217 239.5-334.5T160-552q0-150 96.5-239T480-880q127 0 223.5 89T800-552q0 100-79.5 217.5T480-80Zm0-480Z"/></svg></div>
                    <div class="info-content">
                        <h3>Available for Consultations in NZ</h3>
                        <p>Based in Christchurch<br>Canterbury, New Zealand 8011</p>
                    </div>
                </div>
                
                <div class="info-item">
                    <div class="info-icon"><svg xmlns="http://www.w3.org/2000/svg" height="40px" viewBox="0 -960 960 960" width="40px" fill="#000000"><path d="M770.67-484.67q-3.34-119.66-86.5-202.83Q601-770.67 481.33-774v-66.67q73 1.34 137.17 29.84 64.17 28.5 112.33 76.66Q779-686 807.5-621.83q28.5 64.16 29.83 137.16h-66.66Zm-166 0q-3.34-50-38.34-84.66-35-34.67-85-38V-674q77.67 3.33 132.17 57.5 54.5 54.17 57.83 131.83h-66.66ZM796-120q-119 0-240-55.5T333-333Q231-435 175.5-556T120-796q0-18.86 12.57-31.43T164-840h147.33q14 0 24.34 9.83Q346-820.33 349.33-806l26.62 130.43q2.05 14.9-.62 26.24-2.66 11.33-10.82 19.48L265.67-530q24 41.67 52.5 78.5T381-381.33q35 35.66 73.67 65.5Q493.33-286 536-262.67l94.67-96.66q9.66-10.34 23.26-14.5 13.61-4.17 26.74-2.17L806-349.33q14.67 4 24.33 15.53Q840-322.27 840-308v144q0 18.86-12.57 31.43T796-120ZM233-592l76-76.67-21-104.66H187q3 41.66 13.67 86Q211.33-643 233-592Zm365.33 361.33q40.34 18.34 85.84 29.67 45.5 11.33 89.16 13.67V-288l-100-20.33-75 77.66ZM233-592Zm365.33 361.33Z"/></svg></div>
                    <div class="info-content">
                        <h3>Call Us</h3>
                        <p>Mobile: <a href="tel:+64211752398">+64 21 175 2398</a></p>
                    </div>
                </div>
                
                <div class="info-item">
                    <div class="info-icon"><svg xmlns="http://www.w3.org/2000/svg" height="40px" viewBox="0 -960 960 960" width="40px" fill="#000000"><path d="M146.67-160q-27 0-46.84-19.83Q80-199.67 80-226.67v-506.66q0-27 19.83-46.84Q119.67-800 146.67-800h666.66q27 0 46.84 19.83Q880-760.33 880-733.33v506.66q0 27-19.83 46.84Q840.33-160 813.33-160H146.67ZM480-454.67 146.67-670v443.33h666.66V-670L480-454.67Zm0-66.66 330.67-212H150l330 212ZM146.67-670v-63.33V-226.67-670Z"/></svg></div>
                    <div class="info-content">
                        <h3>Email Us</h3>
                        <p>General: <a href="mailto:matt@Finical3D.co.nz">Matt@Finical3D.co.nz</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

<script is:inline>
    document.querySelectorAll('.service-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.service-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            const serviceInput = document.getElementById('serviceType');
            if (serviceInput) serviceInput.value = btn.dataset.value ?? '';
        });
    });

    const qtyInput = document.getElementById('quantity');

    document.getElementById('qtyUp')?.addEventListener('click', () => {
        if (qtyInput) qtyInput.value = String(parseInt(qtyInput.value || '0') + 1);
    });

    document.getElementById('qtyDown')?.addEventListener('click', () => {
        if (qtyInput && parseInt(qtyInput.value) > 1) qtyInput.value = String(parseInt(qtyInput.value) - 1);
    });

    const contactForm = document.getElementById('contactForm');
    if (contactForm) {
        contactForm.addEventListener('submit', (e) => {
            e.preventDefault();

            const submitBtn = contactForm.querySelector('.form-submit');
            const originalText = submitBtn.textContent;
            submitBtn.textContent = 'Sending...';
            submitBtn.style.opacity = '0.7';
            submitBtn.disabled = true;

            const formData = new FormData(contactForm);

            fetch('https://api.web3forms.com/submit', {
                method: 'POST',
                body: formData,
                headers: { 'Accept': 'application/json' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    submitBtn.textContent = 'Message Sent! ✓';
                    submitBtn.style.background = '#4CAF50';
                    contactForm.reset();
                    document.querySelectorAll('.service-btn').forEach(b => b.classList.remove('active'));
                } else {
                    submitBtn.textContent = 'Something went wrong';
                    submitBtn.style.background = '#e53e3e';
                }
                setTimeout(() => {
                    submitBtn.textContent = originalText;
                    submitBtn.style.background = '';
                    submitBtn.style.opacity = '';
                    submitBtn.disabled = false;
                }, 3000);
            })
            .catch(() => {
                submitBtn.textContent = 'Error — try again';
                submitBtn.style.background = '#e53e3e';
                submitBtn.disabled = false;
            });
        });
    }
</script>
</section>

<style>
    :global(.contact) {
        padding-top: 60px;
        padding-bottom: 60px;
    }

    .contact-header {
        padding-top: 40px;
        margin-bottom: 40px;
    }

    :global(.contact-content) {
        align-items: start;
    }

    :global(.contact-info) {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    :global(.info-item) {
        margin-bottom: 0;
    }

    input[type="date"] {
        color-scheme: dark;
    }

    .service-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .service-btn {
        padding: 12px 24px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--text-muted);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        transition: all 0.3s ease;
        border-radius: 4px;
        font-family: inherit;
    }

    .service-btn.active {
        background: var(--accent);
        border-color: var(--accent);
        color: #000000;
    }

    input[type="number"]::-webkit-inner-spin-button,
    input[type="number"]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        appearance: none;
    }

    input[type="number"] {
        -moz-appearance: textfield;
    }

    .quantity-wrapper {
        display: flex;
        width: 100px;
        align-items: center;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .quantity-wrapper input {
        border: none;
        text-align: center;
        flex: 1;
        border-left: 1px solid rgba(255, 255, 255, 0.1);
        border-right: 1px solid rgba(255, 255, 255, 0.1);
    }

    .quantity-wrapper input:focus {
        box-shadow: none;
    }

    .qty-btn {
        width: 30px;
        height: 45px;
        background: rgba(255, 255, 255, 0.05);
        border: none;
        color: var(--accent);
        font-size: 20px;
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: inherit;
        flex-shrink: 0;
    }

    .qty-btn:hover {
        background: var(--accent);
        color: white;
    }

    @media (max-width: 768px) {
        .quantity-wrapper {
            width: 100%;
        }

        .qty-btn {
            width: 50px;
            height: 49px;
        }

        .service-buttons {
            justify-content: center;
        }
    }
</style>